# Copy to prod-ssh.env and fill in. Do not commit prod-ssh.env.

# cPanel SSH login
SSH_HOST=donorconnect.glowingdark.com
SSH_PORT=22
SSH_USER=your_cpanel_username

# Preferred: path to your private SSH key (leave empty to use password)
SSH_KEY=

# Only used if SSH_KEY is empty (requires: brew install hudochenkov/sshpass/sshpass)
SSH_PASSWORD=

# Absolute path to the Laravel app on the server (folder that contains artisan)
# Examples:
#   /home/youruser/donorconnect.glowingdark.com
#   /home/youruser/public_html
REMOTE_APP_PATH=/home/youruser/path/to/laravel
